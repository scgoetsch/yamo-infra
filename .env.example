# YAMO Stack — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Required for docker-compose ──────────────────────────────────────────────
# 64-char random string: openssl rand -hex 64
YAMO_BRIDGE_SECRET_KEY_BASE=

# ── LLM provider (set at least one) ──────────────────────────────────────────
ZAI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Active LLM provider: zai | openai | anthropic | ollama
LLM_PROVIDER=zai
LLM_MODEL=
LLM_BASE_URL=

# ── Embeddings ────────────────────────────────────────────────────────────────
# "local" uses @xenova/transformers (no API key needed); "openai" uses API
EMBEDDING_MODEL_TYPE=local
EMBEDDING_MODEL_NAME=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── Bridge auth ───────────────────────────────────────────────────────────────
# Set to "true" to enable Ed25519 device authentication
YAMO_BRIDGE_AUTH_ENABLED=false

# ── Optional features ─────────────────────────────────────────────────────────
# Autonomous SRE alert agent — requires YAMO_SLACK_WEBHOOK_URL for notifications
YAMO_SRE_ENABLED=false
YAMO_SLACK_WEBHOOK_URL=
YAMO_PD_API_KEY=

# Auto-ingest inbox directory (e.g. /home/user/.yamo/inbox)
YAMO_INBOX_DIR=

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin password (default: admin)
GRAFANA_PASSWORD=admin

# ── Log level: quiet | info | debug ──────────────────────────────────────────
LOG_LEVEL=info
